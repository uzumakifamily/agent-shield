# ─────────────────────────────────────────────────────────────────
# AgentShield — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────

# ── Server ───────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development            # Set to "production" on Railway

# ── JWT ──────────────────────────────────────────────────────────
# Minimum 32 characters. Generate with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace_with_at_least_32_char_random_string

# ── Database ─────────────────────────────────────────────────────
# Path to the SQLite file. Defaults to ./data/shield.db if not set.
# On Railway with a volume mounted at /data, set: DB_PATH=/data/shield.db
DATABASE_PATH=./shield.db

# ── Email (Brevo transactional API) ──────────────────────────────
# Get your API key at: https://app.brevo.com/settings/keys/api
BREVO_API_KEY=xkeysib-replace-this
EMAIL_FROM=noreply@yourdomain.com
EMAIL_FROM_NAME=AgentShield

# ── Google OAuth (optional) ──────────────────────────────────────
# Create OAuth 2.0 credentials at: https://console.cloud.google.com/apis/credentials
# Authorised redirect URI: https://your-domain.com/api/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Frontend URL (for CORS allowlist) ────────────────────────────
# Only needed if your frontend is on a domain not in the built-in CORS_ORIGINS set.
FRONTEND_URL=

# ── Acceptance testing (CI only) ─────────────────────────────────
# Set a random string to enable POST /api/auth/test-token.
# Leave empty in production.
ACCEPTANCE_TEST_KEY=

# ── Telegram alerts (optional) ───────────────────────────────────
# Configured per-workspace in the dashboard. Not required at the server level.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Payment webhooks (optional) ──────────────────────────────────
# RAZORPAY_WEBHOOK_SECRET=
# PAYPAL_WEBHOOK_ID=
