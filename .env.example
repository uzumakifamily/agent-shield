# ─────────────────────────────────────────────────────────────────
# AgentShield Core — Environment Variables
# Copy to .env and fill in values.  NEVER commit .env to git.
# ─────────────────────────────────────────────────────────────────

# ── Server ────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development          # Set to "production" on Railway / server

# ── Database ──────────────────────────────────────────────────────
# Path to the SQLite file.
# On Railway with a volume at /data:  DATABASE_PATH=/data/shield.db
DATABASE_PATH=./shield.db

# ── Workspace ─────────────────────────────────────────────────────
# All actions are logged under this workspace ID.
# Default is "default" — change if you're running multiple instances.
WORKSPACE_ID=default

# ── CORS ──────────────────────────────────────────────────────────
# Set to your frontend origin. Defaults to * if not set.
CORS_ORIGIN=http://localhost:3000

# ── Telegram Approval Alerts (optional) ───────────────────────────
# When an action is PAUSED for approval, AgentShield sends a Telegram message.
# Get a bot token from @BotFather and find your chat ID with @userinfobot.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
